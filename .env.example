# Supabase — create a project at https://supabase.com and copy from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: AI chat (server-only; add in Vercel → Project → Settings → Environment Variables)
# OPENAI_API_KEY=

# Vet RAG + agent API (FastAPI in vet-rag-api). Deploy API elsewhere, then set the public HTTPS URL.
# Example production: https://your-api.railway.app
# VET_RAG_API_URL=
# Optional shared secret if you add auth on the Python service
# VET_RAG_API_SECRET=

# --- Vercel / production ---
# In Supabase → Authentication → URL configuration, set:
#   Site URL: https://your-app.vercel.app
#   Redirect URLs: https://your-app.vercel.app/auth/callback
# (Add preview URLs if you use Supabase auth on preview deployments.)
